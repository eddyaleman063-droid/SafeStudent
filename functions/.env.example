# Mercado Pago - Production Access Token
# Get it from: https://www.mercadopago.com.pe/settings/account/credentials
# IMPORTANT: Deploy via `firebase functions:config:set mercadopago.access_token="APP_USR-xxx-xxx"`
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx

# Mercado Pago - Test Access Token (for development)
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxx

# Webhook secret for verifying Mercado Pago notifications (optional but recommended)
# MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret

# Firebase project ID
FIREBASE_PROJECT_ID=sagen-bdd3f

# Deployment:
# 1. firebase functions:config:set mercadopago.access_token="APP_USR-xxx"
# 2. firebase deploy --only functions
