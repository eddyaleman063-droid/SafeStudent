# SAGEN — API Keys & Release Config
# Copy this file to .env and fill in your keys.
#
# Development (run with --dart-define):
#   flutter run --dart-define=GEMINI_API_KEY=<key>
#
# Release (env vars are set permanently via setx, or use android/key.properties):
#   SAGEN_STORE_PASSWORD  — password del keystore release
#   SAGEN_KEY_ALIAS       — alias de la clave (sagen)
#   SAGEN_KEY_PASSWORD    — password de la clave
#
# Facebook Key Hash for release (añadir en Facebook Developers → Settings):
#   /dNp5KaQbfWC57sytQ0Q+2AaFec=

GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
